{
  "name": "obts",
  "version": "0.1.14",
  "private": true,
  "type": "module",
  "description": "Obsidian True Sync deployable dashboard and conflict resolution implementation.",
  "bin": {
    "obts": "./dist/src/cli.js"
  },
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "npm run build:dashboard && tsc -p tsconfig.json",
    "build:dashboard": "vite build --config frontend/dashboard/vite.config.ts",
    "check": "tsc -p tsconfig.json --noEmit && vite build --config frontend/dashboard/vite.config.ts --mode check",
    "lint": "npm run check",
    "test": "npm run build:dashboard && vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/multipart": "^9.3.0",
    "@node-rs/argon2": "^2.0.2",
    "fastify": "^5.9.0",
    "isomorphic-git": "^1.38.5",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@types/node": "^24.0.8",
    "svelte": "^5.56.4",
    "typescript": "^5.9.2",
    "vite": "^7.3.6",
    "vitest": "^3.2.4"
  }
}
